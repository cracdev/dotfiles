# Start Claude Code in a new tmux session if not already in tmux
claude() {
  if [ -n "$TMUX" ]; then
    command claude "$@"
  else
    local date_str folder session_name
    date_str=$(date +%Y-%m-%d)
    folder=$(basename "$PWD")
    session_name="${date_str}-${folder}"
    tmux new-session -d -s "$session_name" -n dev -c "$PWD"
    tmux send-keys -t "$session_name:dev" "claude $*" Enter
    tmux new-window -t "$session_name" -n shell -c "$PWD"
    tmux select-window -t "$session_name:dev"
    tmux attach-session -t "$session_name"
  fi
}
