#trash mapping to rm
# install this https://www.npmjs.com/package/trash-cli
# wrapper strips flags like -rf so trash-cli doesn't choke
rm() {
  local args=()
  for arg in "$@"; do
    [[ "$arg" =~ ^- ]] || args+=("$arg")
  done
  command trash "${args[@]}"
}

